{
  "version": 7,
  "variables": [],
  "tiles": {
    "0": {
      "type": "markdown",
      "title": "",
      "content": "# 🎩 OpenClaw AI Agent Observability\n\nReal-time monitoring of AI agent operations, token usage, costs, and security."
    },
    "1": {
      "type": "data",
      "title": "Total Agents Active",
      "query": "timeseries count = count(gen_ai.client.operation.duration), by:{gen_ai.agent.name}\n| summarize agents = countDistinct(gen_ai.agent.name)",
      "queryConfig": {
        "additionalFilters": {},
        "version": "4.3.1",
        "datatype": "metrics"
      },
      "subType": "singleValue",
      "visualization": "singleValue",
      "visualizationSettings": {
        "thresholds": [],
        "chartSettings": {
          "gapPolicy": "connect"
        },
        "singleValue": {
          "showLabel": true,
          "label": "Active Agents",
          "prefixIcon": "UserGroupIcon"
        }
      }
    },
    "2": {
      "type": "data",
      "title": "Monthly Token Cost (USD)",
      "query": "timeseries cost = sum(openclaw.llm.cost_usd)\n| summarize total_cost = sum(cost)\n| fieldsAdd total_cost = round(total_cost, decimals: 2)",
      "subType": "singleValue",
      "visualization": "singleValue",
      "visualizationSettings": {
        "thresholds": [
          { "field": "total_cost", "title": "Cost", "isEnabled": true, "rules": [
            { "color": { "Default": "#7dc540" }, "comparator": "≥", "value": 0 },
            { "color": { "Default": "#f5d30f" }, "comparator": "≥", "value": 50 },
            { "color": { "Default": "#dc172a" }, "comparator": "≥", "value": 200 }
          ]}
        ],
        "singleValue": {
          "showLabel": true,
          "label": "Monthly Cost",
          "prefixIcon": "CostsIcon",
          "autoscale": true
        }
      }
    },
    "3": {
      "type": "data",
      "title": "Avg Agent Health Score",
      "query": "timeseries avg_health = avg(paperclip.agent.health.score), by:{agent_name}\n| summarize overall = avg(avg_health)",
      "subType": "singleValue",
      "visualization": "singleValue",
      "visualizationSettings": {
        "thresholds": [
          { "field": "overall", "title": "Health", "isEnabled": true, "rules": [
            { "color": { "Default": "#dc172a" }, "comparator": "≥", "value": 0 },
            { "color": { "Default": "#f5d30f" }, "comparator": "≥", "value": 50 },
            { "color": { "Default": "#7dc540" }, "comparator": "≥", "value": 80 }
          ]}
        ],
        "singleValue": {
          "showLabel": true,
          "label": "Health Score",
          "prefixIcon": "HealthIcon"
        }
      }
    },
    "4": {
      "type": "data",
      "title": "Active Issues",
      "query": "timeseries issues = avg(paperclip.issues.count), by:{status}\n| summarize total = sum(issues)",
      "subType": "singleValue",
      "visualization": "singleValue",
      "visualizationSettings": {
        "singleValue": {
          "showLabel": true,
          "label": "Active Issues",
          "prefixIcon": "LogsWarningIcon"
        }
      }
    },
    "5": {
      "type": "markdown",
      "title": "",
      "content": "## 📊 Token Usage"
    },
    "6": {
      "type": "data",
      "title": "Token Usage by Model & Type",
      "query": "timeseries usage = sum(gen_ai.client.token.usage), by:{gen_ai.token.type, gen_ai.request.model}",
      "visualization": "categoricalBarChart",
      "visualizationSettings": {
        "chartSettings": {
          "categoricalBarChartSettings": {
            "categoryAxis": "gen_ai.request.model",
            "categoryAxisLabel": "Model",
            "valueAxis": "usage",
            "valueAxisLabel": "Tokens"
          }
        }
      }
    },
    "7": {
      "type": "data",
      "title": "Token Usage Over Time (Input vs Output)",
      "query": "timeseries {\n  input_tokens = sum(gen_ai.client.token.usage, {gen_ai.token.type=\"input\"}),\n  output_tokens = sum(gen_ai.client.token.usage, {gen_ai.token.type=\"output\"})\n}",
      "visualization": "lineChart",
      "visualizationSettings": {
        "chartSettings": {
          "legend": { "position": "bottom" },
          "leftYAxisSettings": { "label": "Tokens" }
        }
      }
    },
    "8": {
      "type": "data",
      "title": "Cache Hit Rate",
      "query": "timeseries {\n  cache_read = sum(gen_ai.client.token.usage, {gen_ai.token.type=\"cache_read\"}),\n  input = sum(gen_ai.client.token.usage, {gen_ai.token.type=\"input\"})\n}\n| fieldsAdd cache_rate = if(input > 0, 100 * cache_read / input, 0)",
      "visualization": "lineChart",
      "visualizationSettings": {
        "chartSettings": {
          "leftYAxisSettings": { "label": "Cache Hit %" }
        }
      }
    },
    "9": {
      "type": "markdown",
      "title": "",
      "content": "## 💰 Cost by Agent"
    },
    "10": {
      "type": "data",
      "title": "Cost by Agent (USD)",
      "query": "timeseries cost = sum(paperclip.cost.cents), by:{agent_id, model}\n| fieldsAdd cost_usd = cost / 100",
      "visualization": "barChart",
      "visualizationSettings": {
        "chartSettings": {
          "legend": { "position": "right" },
          "leftYAxisSettings": { "label": "Cost (USD)" }
        }
      }
    },
    "11": {
      "type": "data",
      "title": "Cost Trend — Last 30 Days",
      "query": "timeseries cost = sum(openclaw.llm.cost_usd), by:{gen_ai.response.model}\n| fieldsAdd cumulative = running_sum(cost)",
      "visualization": "areaChart",
      "visualizationSettings": {
        "chartSettings": {
          "legend": { "position": "bottom" },
          "leftYAxisSettings": { "label": "Cumulative Cost (USD)" }
        }
      }
    },
    "12": {
      "type": "markdown",
      "title": "",
      "content": "## ⚡ Agent Performance"
    },
    "13": {
      "type": "data",
      "title": "Operation Duration by Provider",
      "query": "timeseries avg_duration = avg(gen_ai.client.operation.duration), by:{gen_ai.provider.name}",
      "visualization": "lineChart",
      "visualizationSettings": {
        "chartSettings": {
          "legend": { "position": "bottom" },
          "leftYAxisSettings": { "label": "Duration (s)" }
        }
      }
    },
    "14": {
      "type": "data",
      "title": "P95 Operation Duration",
      "query": "timeseries p95 = percentile(gen_ai.client.operation.duration, 95), by:{gen_ai.provider.name}",
      "visualization": "lineChart",
      "visualizationSettings": {
        "chartSettings": {
          "leftYAxisSettings": { "label": "P95 Duration (s)" }
        }
      }
    },
    "15": {
      "type": "data",
      "title": "Tool Call Frequency",
      "query": "fetch spans\n| filter matchesPhrase(span.name, \"tool.\")\n| summarize calls = count(), by:{span.name}\n| sort calls desc\n| limit 20",
      "visualization": "barChart",
      "visualizationSettings": {
        "chartSettings": {
          "categoricalBarChartSettings": {
            "categoryAxis": "span.name",
            "categoryAxisLabel": "Tool",
            "valueAxis": "calls",
            "valueAxisLabel": "Call Count"
          }
        }
      }
    },
    "16": {
      "type": "data",
      "title": "Avg Tool Duration (Top 10)",
      "query": "fetch spans\n| filter matchesPhrase(span.name, \"tool.\")\n| summarize avg_ms = avg(duration / 1000000), by:{span.name}\n| sort avg_ms desc\n| limit 10",
      "visualization": "barChart"
    },
    "17": {
      "type": "markdown",
      "title": "",
      "content": "## 📋 Issue Flow"
    },
    "18": {
      "type": "data",
      "title": "Issues by Status Over Time",
      "query": "timeseries issues = avg(paperclip.issues.count), by:{status}",
      "visualization": "areaChart",
      "visualizationSettings": {
        "chartSettings": {
          "legend": { "position": "bottom" },
          "leftYAxisSettings": { "label": "Issues" }
        }
      }
    },
    "19": {
      "type": "data",
      "title": "Issue Completion Rate",
      "query": "timeseries {\n  done = avg(paperclip.issues.count, {status=\"done\"}),\n  total = avg(paperclip.issues.count)\n}\n| fieldsAdd completion_rate = if(total > 0, 100 * done / total, 0)",
      "visualization": "lineChart",
      "visualizationSettings": {
        "chartSettings": {
          "leftYAxisSettings": { "label": "Completion %" }
        }
      }
    },
    "20": {
      "type": "markdown",
      "title": "",
      "content": "## 💸 Budget Utilization"
    },
    "21": {
      "type": "data",
      "title": "Budget Utilization by Agent",
      "query": "timeseries utilization = avg(paperclip.budget.utilization), by:{agent_name}",
      "visualization": "lineChart",
      "visualizationSettings": {
        "chartSettings": {
          "legend": { "position": "bottom" },
          "leftYAxisSettings": { "label": "Utilization %" }
        },
        "thresholds": [
          { "field": "utilization", "isEnabled": true, "rules": [
            { "color": { "Default": "#7dc540" }, "comparator": "≥", "value": 0 },
            { "color": { "Default": "#f5d30f" }, "comparator": "≥", "value": 80 },
            { "color": { "Default": "#dc172a" }, "comparator": "≥", "value": 100 }
          ]}
        ]
      }
    },
    "22": {
      "type": "data",
      "title": "Budget Status Table",
      "query": "timeseries {\n  util = avg(paperclip.budget.utilization),\n  cost = sum(paperclip.cost.cents)\n}, by:{agent_name}\n| fieldsAdd cost_usd = cost / 100\n| fieldsAdd status = if(util >= 100, \"🔴 Paused\", if(util >= 80, \"🟡 Warning\", \"🟢 OK\"))",
      "visualization": "table",
      "visualizationSettings": {
        "table": {
          "enableLineWrap": true
        }
      }
    },
    "23": {
      "type": "markdown",
      "title": "",
      "content": "## 🔒 Security Overview"
    },
    "24": {
      "type": "data",
      "title": "Security Events",
      "query": "timeseries {\n  file_access = sum(openclaw.security.sensitive_file_access),\n  injection = sum(openclaw.security.prompt_injection),\n  dangerous_cmd = sum(openclaw.security.dangerous_command)\n}",
      "visualization": "lineChart",
      "visualizationSettings": {
        "chartSettings": {
          "legend": { "position": "bottom" },
          "leftYAxisSettings": { "label": "Events" }
        }
      }
    },
    "25": {
      "type": "data",
      "title": "Recent Security Incidents",
      "query": "fetch spans\n| filter security.event.detected == true\n| fields timestamp, security.event.detection, security.event.severity, security.event.description, openclaw.session.key\n| sort timestamp desc\n| limit 20",
      "visualization": "table"
    }
  },
  "layouts": {
